# Application Environment
# Options: development | paper | live
# NEVER set to 'live' without understanding all implications
APP_ENV=paper
LOG_LEVEL=INFO

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=300

# Market Data Provider
# Options: alpaca | mock
# Use 'mock' for local development and testing
MARKET_DATA_PROVIDER=mock

# Alpaca Markets (required only when MARKET_DATA_PROVIDER=alpaca)
# Paper trading: https://paper-api.alpaca.markets
# Live trading: https://api.alpaca.markets (CAUTION: real money)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Risk Parameters (conservative defaults — adjust with caution)
MAX_POSITION_PCT=0.05
MAX_DAILY_DRAWDOWN_PCT=0.02
MAX_GROSS_EXPOSURE_PCT=0.80
MAX_CONCURRENT_POSITIONS=10

# Paper Trading
PAPER_FILL_LATENCY_MS=50
SLIPPAGE_BPS=5
PAPER_STARTING_CASH=100000

# Engine Service
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8100

# MCP Server
MCP_TRANSPORT=stdio
MCP_SSE_PORT=3100
ENGINE_BASE_URL=http://localhost:8100
ENGINE_TIMEOUT_MS=10000

# API Authentication
# Set to false for local development only (only honoured when APP_ENV=development)
SENTINEL_AUTH_ENABLED=false
# Master API key (generate with: python -m sentinel.auth.cli generate --name master --scopes admin)
SENTINEL_MASTER_KEY=
# Additional client keys (JSON array of client records)
SENTINEL_API_KEYS_JSON=[]
RATE_LIMIT_PER_MINUTE=60
