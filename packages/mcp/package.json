{
  "name": "sentinel-execution-mcp",
  "version": "0.1.0",
  "description": "Sentinel Execution MCP — trading control plane MCP interface",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sentinel-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "trading",
    "claude",
    "ai",
    "finance",
    "modelcontextprotocol"
  ],
  "author": "rohith1125",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rohith1125/sentinel-execution-mcp.git"
  },
  "homepage": "https://github.com/rohith1125/sentinel-execution-mcp",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'))\"",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
